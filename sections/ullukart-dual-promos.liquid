{% schema %}
{
  "name": "Ullu-Kart Dual Promos",
  "max_blocks": 2,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#F8F9FA"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "promo_banner",
      "name": "Promo Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image",
          "info": "Upload a portrait or square image (e.g., 600x800px)."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Banner Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ullu-Kart Dual Promos",
      "blocks": [
        { "type": "promo_banner" },
        { "type": "promo_banner" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .uk-promos-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_vertical }}px 15px;
    width: 100%;
    box-sizing: border-box;
  }

  .uk-promos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* Exactly 50% width each */
    gap: 12px;
    max-width: 800px; /* Limits width on ultra-wide screens */
    margin: 0 auto;
  }

  .uk-promo-item {
    position: relative;
    display: block;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    background-color: #e2e8f0; /* Placeholder background */
    aspect-ratio: 4 / 5; /* Creates a nice portrait poster shape */
  }

  .uk-promo-item:active {
    transform: scale(0.97);
  }

  .uk-promo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder Styling for Theme Editor */
  .uk-promo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: sans-serif;
    font-size: 13px;
    font-weight: bold;
    color: #64748b;
    text-align: center;
    padding: 20px;
    box-sizing: border-box;
  }

  /* Desktop Adjustments */
  @media (min-width: 769px) {
    .uk-promos-grid {
      gap: 20px;
    }
    .uk-promo-item {
      aspect-ratio: 16 / 9; /* Wider banners for PC */
    }
    .uk-promo-item:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.12);
    }
  }
</style>

<div class="uk-promos-wrapper">
  <div class="uk-promos-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="uk-promo-item" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          <img src="{{ block.settings.image | img_url: '600x' }}" alt="Promo Banner" loading="lazy">
        {% else %}
          <div class="uk-promo-placeholder">Add Banner Image</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</div>