{% schema %}
{
  "name": "Ullu-Kart Swipe Deal",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "⚡ DEAL OF THE DAY"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#F8F9FA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Main Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Unlocked Price Color",
      "default": "#ef4444"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Unlocked Button Color",
      "default": "#FF7A00"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Auto-Swipe Speed",
      "default": 3
    },
    {
      "type": "header",
      "content": "⏳ Urgency Settings"
    },
    {
      "type": "number",
      "id": "timer_hours",
      "label": "Countdown Hours",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "deal",
      "name": "Deal Product",
      "limit": 8,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ullu-Kart Swipe Deal",
      "blocks": [
        { "type": "deal" },
        { "type": "deal" },
        { "type": "deal" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .uk-3d-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding: 40px 15px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    overflow: hidden;
  }

  .uk-3d-header {
    text-align: center;
    margin-bottom: 20px;
  }

  .uk-3d-heading {
    font-size: 24px;
    font-weight: 900;
    color: {{ section.settings.text_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
    animation: textPop 2s ease-in-out infinite;
  }

  @keyframes textPop {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  /* Countdown Timer */
  .uk-timer-wrap {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 15px;
  }
  .uk-timer-box {
    background: #111111;
    color: #ffffff;
    padding: 6px 10px;
    border-radius: 6px;
    font-weight: 800;
    font-size: 16px;
    min-width: 45px;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }
  .uk-timer-colon {
    font-weight: 900;
    font-size: 18px;
    color: #111111;
    line-height: 32px;
  }

  /* Floating Image Area (No White Box) */
  .uk-image-slider-wrap {
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1 / 1;
    position: relative;
    margin: 0 auto 10px auto;
  }

  /* Swipeable Track */
  .uk-image-track {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .uk-image-track::-webkit-scrollbar {
    display: none;
  }

  .uk-image-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    box-sizing: border-box;
  }

  .uk-image-slide img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    /* Soft shadow to make transparent images pop */
    filter: drop-shadow(0px 15px 25px rgba(0,0,0,0.15)); 
  }

  /* Dots */
  .uk-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    position: absolute;
    bottom: 5px;
    width: 100%;
    z-index: 5;
  }
  .uk-dot { width: 8px; height: 8px; border-radius: 50%; background: #cbd5e1; transition: 0.3s; cursor: pointer; }
  .uk-dot.is-active { background: #111111; width: 16px; border-radius: 4px; }

  /* Static Text Area */
  .uk-text-area {
    text-align: center;
    max-width: 380px;
    margin: 0 auto;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .uk-text-area.is-fading {
    opacity: 0;
    transform: translateY(5px);
  }

  .uk-static-title {
    color: {{ section.settings.text_color }};
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 10px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Price Area */
  .uk-static-price-row {
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    height: 35px;
  }

  .uk-locked-text {
    font-size: 24px;
    font-weight: 900;
    color: #94A3B8;
    letter-spacing: 2px;
  }

  .uk-unlocked-text {
    font-size: 26px;
    font-weight: 900;
    color: {{ section.settings.price_color }};
    animation: pricePop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .uk-static-compare {
    font-size: 14px;
    color: #94A3B8;
    text-decoration: line-through;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .uk-static-compare.is-visible {
    opacity: 1;
  }

  @keyframes pricePop {
    0% { transform: scale(0.5); opacity: 0; }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }

  /* The Gamified Button */
  .uk-deal-btn {
    display: block;
    width: 100%;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    padding: 16px;
    border-radius: 10px;
    letter-spacing: 1px;
    border: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
  }

  /* Unlocked State = Theme Color */
  .uk-deal-btn.is-unlocked {
    background: {{ section.settings.btn_color }};
    color: #ffffff;
    box-shadow: 0 5px 0px rgba(0,0,0,0.2);
  }

  /* Locked State = Pure Black */
  .uk-deal-btn.is-locked {
    background: #000000 !important;
    color: #ffffff !important;
    box-shadow: 0 5px 0px rgba(0,0,0,0.3);
  }

  .uk-deal-btn.btn-pop {
    transform: scale(0.92) translateY(3px);
    box-shadow: 0 0px 0px rgba(0,0,0,0);
  }
</style>

<div class="uk-3d-wrapper" id="ukDealWrapper-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}" data-timer="{{ section.settings.timer_hours }}">
  
  <div class="uk-3d-header">
    <h2 class="uk-3d-heading">{{ section.settings.heading }}</h2>
  </div>

  <div class="uk-timer-wrap">
    <div class="uk-timer-box" id="ukHr-{{ section.id }}">00</div><span class="uk-timer-colon">:</span>
    <div class="uk-timer-box" id="ukMin-{{ section.id }}">00</div><span class="uk-timer-colon">:</span>
    <div class="uk-timer-box" id="ukSec-{{ section.id }}">00</div>
  </div>

  <div class="uk-image-slider-wrap">
    <div class="uk-image-track" id="ukImageTrack-{{ section.id }}">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        <div class="uk-image-slide" 
             data-index="{{ forloop.index0 }}"
             data-title="{{ product.title | default: 'Ullu-Kart Premium Device' | escape }}"
             data-price="{{ product.price | default: 99900 | money_without_trailing_zeros }}"
             data-compare="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | money_without_trailing_zeros }}{% endif %}"
             data-url="{{ product.url | default: '#' }}"
             {{ block.shopify_attributes }}>
          {% if product != blank and product.featured_image %}
            <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title | escape }}" loading="lazy">
          {% else %}
            <div style="color: #94A3B8; font-weight: bold;">Select Product in Editor</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    
    <div class="uk-dots" id="ukDots-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="uk-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}"></div>
      {% endfor %}
    </div>
  </div>

  <div class="uk-text-area" id="ukTextArea-{{ section.id }}">
    <h3 class="uk-static-title" id="ukTitle-{{ section.id }}">Loading...</h3>
    
    <div class="uk-static-price-row">
      <span id="ukPrice-{{ section.id }}"><span class="uk-locked-text">????</span></span>
      <span class="uk-static-compare" id="ukCompare-{{ section.id }}"></span>
    </div>

    <a href="#" class="uk-deal-btn is-locked" id="ukBtn-{{ section.id }}">
      🔒 UNLOCK PRICE
    </a>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const wrapper = document.getElementById('ukDealWrapper-' + sectionId);
    if (!wrapper) return;

    // --- 1. ROBUST COUNTDOWN TIMER ---
    const timerHours = parseInt(wrapper.getAttribute('data-timer')) || 12;
    const hrEl = document.getElementById('ukHr-' + sectionId);
    const minEl = document.getElementById('ukMin-' + sectionId);
    const secEl = document.getElementById('ukSec-' + sectionId);
    
    let endTime = localStorage.getItem('uk_timer_end_' + sectionId);
    if (!endTime || new Date().getTime() > endTime) {
      endTime = new Date().getTime() + (timerHours * 60 * 60 * 1000);
      localStorage.setItem('uk_timer_end_' + sectionId, endTime);
    }

    function updateTimer() {
      let now = new Date().getTime();
      let distance = endTime - now;
      if (distance < 0) {
        endTime = new Date().getTime() + (timerHours * 60 * 60 * 1000);
        localStorage.setItem('uk_timer_end_' + sectionId, endTime);
        distance = endTime - now;
      }
      let h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      let m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      let s = Math.floor((distance % (1000 * 60)) / 1000);
      
      if(hrEl) hrEl.innerText = (h < 10 ? "0" : "") + h;
      if(minEl) minEl.innerText = (m < 10 ? "0" : "") + m;
      if(secEl) secEl.innerText = (s < 10 ? "0" : "") + s;
    }
    updateTimer(); 
    setInterval(updateTimer, 1000);

    // --- 2. SWIPE & UNLOCK LOGIC ---
    const track = document.getElementById('ukImageTrack-' + sectionId);
    if (!track) return;
    
    const slides = track.querySelectorAll('.uk-image-slide');
    const dots = document.querySelectorAll('#ukDots-' + sectionId + ' .uk-dot');
    
    const textArea = document.getElementById('ukTextArea-' + sectionId);
    const titleEl = document.getElementById('ukTitle-' + sectionId);
    const priceEl = document.getElementById('ukPrice-' + sectionId);
    const compareEl = document.getElementById('ukCompare-' + sectionId);
    const btnEl = document.getElementById('ukBtn-' + sectionId);
    
    const speed = parseInt(wrapper.getAttribute('data-speed')) || 3000;
    let currentIndex = 0;
    let autoPlayInterval;
    let swipeDirection = 1;
    let isPriceUnlocked = false; 

    if (slides.length < 1) return;

    // UNLOCK BUTTON CLICK
    btnEl.addEventListener('click', function(e) {
      if (!isPriceUnlocked) {
        e.preventDefault(); 
        
        // Pop Animation
        btnEl.classList.add('btn-pop');
        setTimeout(() => btnEl.classList.remove('btn-pop'), 200);

        // Reveal Price
        const activeSlide = slides[currentIndex];
        priceEl.innerHTML = '<span class="uk-unlocked-text">🎉 ' + activeSlide.getAttribute('data-price') + '</span>';
        
        if (activeSlide.getAttribute('data-compare')) {
          compareEl.innerText = activeSlide.getAttribute('data-compare');
          compareEl.classList.add('is-visible');
        }

        // Change button to Active
        btnEl.classList.remove('is-locked');
        btnEl.classList.add('is-unlocked');
        btnEl.innerText = 'ADD TO CART 🛍️';
        btnEl.href = activeSlide.getAttribute('data-url');
        
        isPriceUnlocked = true;
        
        // STOP SWIPING
        stopAutoPlay();
      }
    });

    function updateTextForSlide(index) {
      textArea.classList.add('is-fading');
      
      setTimeout(() => {
        const activeSlide = slides[index];
        titleEl.innerText = activeSlide.getAttribute('data-title');
        
        // Reset to Locked State
        isPriceUnlocked = false;
        priceEl.innerHTML = '<span class="uk-locked-text">????</span>';
        compareEl.innerText = '';
        compareEl.classList.remove('is-visible');
        
        btnEl.classList.add('is-locked');
        btnEl.classList.remove('is-unlocked');
        btnEl.innerText = '🔒 UNLOCK PRICE';
        btnEl.href = '#'; 
        
        textArea.classList.remove('is-fading');
      }, 300);
    }

    // Initialize the first slide text
    updateTextForSlide(0);

    // Detect swiping
    track.addEventListener('scroll', function() {
      const index = Math.round(track.scrollLeft / track.clientWidth);
      
      if (index !== currentIndex && slides[index]) {
        currentIndex = index;
        dots.forEach(d => d.classList.remove('is-active'));
        if(dots[index]) dots[index].classList.add('is-active');
        updateTextForSlide(index);
      }
    });

    // Auto-swipe
    function autoScroll() {
      if (currentIndex >= slides.length - 1 && swipeDirection === 1) {
        swipeDirection = -1;
      } else if (currentIndex <= 0 && swipeDirection === -1) {
        swipeDirection = 1;
      }
      const nextIndex = currentIndex + swipeDirection;
      track.scrollTo({ left: nextIndex * track.clientWidth, behavior: 'smooth' });
    }

    function startAutoPlay() { 
        clearInterval(autoPlayInterval);
        autoPlayInterval = setInterval(autoScroll, speed); 
    }
    function stopAutoPlay() { clearInterval(autoPlayInterval); }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        const clickedIndex = parseInt(e.target.getAttribute('data-index'));
        track.scrollTo({ left: clickedIndex * track.clientWidth, behavior: 'smooth' });
      });
    });

    // Pause on touch
    track.addEventListener('touchstart', stopAutoPlay, {passive: true});
    track.addEventListener('touchend', () => { if(!isPriceUnlocked) startAutoPlay(); }, {passive: true});

    startAutoPlay();
});
</script>