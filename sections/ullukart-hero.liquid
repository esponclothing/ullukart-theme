{% schema %}
{
  "name": "Ullu-Kart Hero Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Auto-Swipe Speed",
      "info": "Choose how fast the banners should automatically slide.",
      "default": 3
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Active Dot Color",
      "default": "#FF7A00",
      "info": "Matches the Ullu-Kart brand color"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image (CRITICAL)",
          "info": "Marketplace Standard: Upload 800x400px (2:1 Ratio). Matches Snapdeal/Flipkart mobile view."
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop Image",
          "info": "Upload 1920x600px for PC users."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Banner Link",
          "info": "Link this banner to a product, collection, or page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ullu-Kart Hero Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .uk-hero-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #f1f5f9;
  }
  
  .uk-carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -webkit-overflow-scrolling: touch;
  }
  
  .uk-carousel-track::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .uk-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    position: relative;
    display: block;
    text-decoration: none; /* Prevents underline if image fails to load */
  }

  /* Force Marketplace Aspect Ratios */
  .uk-slide img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  /* Desktop View */
  @media (min-width: 769px) {
    .uk-slide .img-mobile { display: none; }
    .uk-slide .img-desktop { 
      display: block; 
      aspect-ratio: 1920 / 600; 
    }
  }

  /* Mobile View - Flipkart/Snapdeal Style */
  @media (max-width: 768px) {
    .uk-slide .img-desktop { display: none; }
    .uk-slide .img-mobile { 
      display: block; 
      aspect-ratio: 2 / 1; 
    }
  }

  /* Pagination Dots */
  .uk-indicators {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .uk-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    transition: all 0.3s ease;
  }

  .uk-dot.active {
    width: 20px;
    border-radius: 4px;
    background: {{ section.settings.dot_color }};
  }
</style>

<div class="uk-hero-wrapper" id="ukCarousel-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
  <div class="uk-carousel-track" id="ukTrack-{{ section.id }}">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="uk-slide" {{ block.shopify_attributes }}>
        
        {% if block.settings.image_desktop %}
          <img src="{{ block.settings.image_desktop | img_url: '1920x' }}" class="img-desktop" alt="Desktop Banner" loading="lazy">
        {% else %}
          <div class="img-desktop" style="background:#e2e8f0; width:100%; height:100%; display:flex; align-items:center; justify-content:center;">Add Desktop Image</div>
        {% endif %}

        {% if block.settings.image_mobile %}
          <img src="{{ block.settings.image_mobile | img_url: '800x' }}" class="img-mobile" alt="Mobile Banner" loading="lazy">
        {% else %}
          <div class="img-mobile" style="background:#cbd5e1; width:100%; height:100%; display:flex; align-items:center; justify-content:center;">Add Mobile Image (2:1)</div>
        {% endif %}

      </a>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="uk-indicators" id="ukDots-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="uk-dot {% if forloop.first %}active{% endif %}"></div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('ukTrack-{{ section.id }}');
    const dots = document.querySelectorAll('#ukDots-{{ section.id }} .uk-dot');
    const wrapper = document.getElementById('ukCarousel-{{ section.id }}');
    
    // Grabs the speed from the theme editor settings dynamically
    const speed = parseInt(wrapper.getAttribute('data-speed')) || 3000; 
    let slideIndex = 0;
    const totalSlides = dots.length;
    let autoPlayInterval;

    if (totalSlides < 2) return; 

    function updateDots(index) {
      dots.forEach(dot => dot.classList.remove('active'));
      if(dots[index]) dots[index].classList.add('active');
    }

    function scrollToNext() {
      slideIndex = (slideIndex + 1) % totalSlides;
      const slideWidth = track.clientWidth;
      track.scrollTo({ left: slideWidth * slideIndex, behavior: 'smooth' });
      updateDots(slideIndex);
    }

    function startAutoPlay() {
      autoPlayInterval = setInterval(scrollToNext, speed);
    }

    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    // Manual Swipe Detection
    track.addEventListener('scroll', function() {
      const scrollPos = track.scrollLeft;
      const slideWidth = track.clientWidth;
      const newIndex = Math.round(scrollPos / slideWidth);
      if (newIndex !== slideIndex && newIndex < totalSlides) {
        slideIndex = newIndex;
        updateDots(slideIndex);
      }
    });

    wrapper.addEventListener('touchstart', stopAutoPlay, {passive: true});
    wrapper.addEventListener('touchend', startAutoPlay, {passive: true});
    wrapper.addEventListener('mouseenter', stopAutoPlay);
    wrapper.addEventListener('mouseleave', startAutoPlay);

    startAutoPlay();
  });
</script>