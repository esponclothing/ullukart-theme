<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign body_font = section.settings.body_font -%}
{%- assign heading_font = section.settings.heading_font -%}

<style>
  /* Load the chosen Shopify fonts */
  {{ body_font | font_face: font_display: 'swap' }}
  {{ heading_font | font_face: font_display: 'swap' }}

  /* DYNAMIC SETTINGS FROM THEME EDITOR */
  .uk-section-{{ section.id }} {
    --bg-main: {{ section.settings.bg_color }};
    --text-main: {{ section.settings.text_color }};
    --text-muted: {{ section.settings.text_muted }};
    --accent: {{ section.settings.accent_color }};
    --accent-hover: {{ section.settings.accent_hover }};
    --border-light: {{ section.settings.border_light }};
    --border-dark: {{ section.settings.border_dark }};
    
    --footer-pad-top: {{ section.settings.footer_pad_top }}px;
    --footer-pad-bottom: {{ section.settings.footer_pad_bottom }}px;
    --grid-gap: {{ section.settings.footer_grid_gap }}px;

    /* Typography Settings */
    --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
    --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --font-weight-body: {{ body_font.weight | default: 400 }};
    --font-weight-heading: {{ heading_font.weight | default: 700 }};
    --base-size-desktop: {{ section.settings.font_size_desktop }}px;
    --base-size-mobile: {{ section.settings.font_size_mobile }}px;
  }
  
  .uk-footer-wrapper {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: var(--font-body);
    font-weight: var(--font-weight-body);
    font-size: var(--base-size-desktop);
    padding: var(--footer-pad-top) 5% var(--footer-pad-bottom);
    border-top: 1px solid var(--border-light);
  }

  .uk-footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--grid-gap);
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-brand img {
    width: 120px; 
    height: auto; 
    margin-bottom: 25px;
    display: block;
  }

  .footer-brand h2 {
    font-family: var(--font-heading);
    font-size: calc(var(--base-size-desktop) + 10px);
    font-weight: var(--font-weight-heading);
    color: var(--text-main);
    margin: 0 0 15px 0;
    letter-spacing: 1px;
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: var(--base-size-desktop);
    line-height: 1.6;
    max-width: 350px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer-col h4 {
    font-family: var(--font-heading);
    color: var(--text-main);
    font-size: calc(var(--base-size-desktop) + 1px);
    font-weight: var(--font-weight-heading);
    letter-spacing: 1px;
    margin-bottom: 25px;
    text-transform: uppercase;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 15px;
    font-size: var(--base-size-desktop);
    transition: 0.3s;
  }

  .footer-link i {
    color: var(--accent);
    font-size: calc(var(--base-size-desktop) + 2px);
    width: 20px; 
    text-align: center;
    transition: 0.3s;
  }

  .footer-link:hover {
    color: var(--accent-hover);
    transform: translateX(5px);
  }

  .footer-link:hover i {
    color: var(--text-main);
  }

  .contact-link {
    display: inline-flex;
    align-items: flex-start;
    gap: 12px;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 20px;
    font-size: var(--base-size-desktop);
    line-height: 1.5;
    transition: 0.3s;
  }

  .contact-link i { 
    color: var(--accent); 
    margin-top: 4px; 
    font-size: calc(var(--base-size-desktop) + 2px); 
    width: 20px; 
    text-align: center; 
  }
  
  .contact-link:hover { 
    color: var(--text-main); 
  }

  .footer-bottom {
    max-width: 1400px;
    margin: 60px auto 0;
    padding-top: 30px;
    border-top: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .copyright { color: #64748b; font-size: calc(var(--base-size-desktop) - 2px); }
  .social-icons { display: flex; gap: 20px; }
  .social-icons a { color: var(--text-main); font-size: calc(var(--base-size-desktop) + 6px); transition: 0.3s; }
  .social-icons a:hover { color: var(--accent-hover); transform: translateY(-3px); }

  /* ==========================================
     MOBILE PERFECT ALIGNMENT
     ========================================== */
  @media (max-width: 900px) {
    .uk-footer-wrapper {
      font-size: var(--base-size-mobile);
      padding-left: 25px;
      padding-right: 25px;
    }
    .uk-footer-grid { 
      grid-template-columns: 1fr; 
      gap: 35px; 
    }
    
    /* Center the Logo and Description */
    .footer-brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-brand img { 
      width: 100px; 
      margin: 0 auto 20px;
    }
    .footer-brand p {
      max-width: 100%;
      font-size: var(--base-size-mobile);
    }
    .footer-brand h2 {
      font-size: calc(var(--base-size-mobile) + 8px);
    }

    /* Left-Align the Lists for a clean vertical icon line */
    .footer-col {
      align-items: flex-start;
      text-align: left;
    }
    .footer-col h4 {
      font-size: calc(var(--base-size-mobile) + 1px);
      width: 100%;
      border-bottom: 1px solid var(--border-light);
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    .footer-link, .contact-link {
      font-size: var(--base-size-mobile);
      justify-content: flex-start;
    }
    .footer-link i, .contact-link i {
      font-size: calc(var(--base-size-mobile) + 2px);
    }
    .footer-link:hover { transform: none; }
    
    /* Center the copyright and socials at the very bottom */
    .footer-bottom { 
      flex-direction: column; 
      text-align: center; 
      gap: 20px;
      margin-top: 30px;
    }
    .copyright {
      font-size: calc(var(--base-size-mobile) - 2px);
    }
    .social-icons {
      justify-content: center;
    }
  }
</style>

<div class="uk-section-{{ section.id }}">
  <footer class="uk-footer-wrapper">
    <div class="uk-footer-grid">
      <div class="footer-brand">
        {% if section.settings.footer_logo != blank %}
          <img src="{{ section.settings.footer_logo | img_url: '400x' }}" alt="{{ shop.name }}">
        {% else %}
          <h2>ULLU-KART</h2>
        {% endif %}
        <p>{{ section.settings.footer_desc }}</p>
      </div>

      <div class="footer-col">
        <h4>{{ section.settings.col1_title }}</h4>
        {% if section.settings.col1_link1_text != blank %}<a href="{{ section.settings.col1_link1_url }}" class="footer-link">{% if section.settings.col1_link1_icon != blank %}<i class="{{ section.settings.col1_link1_icon }}"></i>{% endif %}<span>{{ section.settings.col1_link1_text }}</span></a>{% endif %}
        {% if section.settings.col1_link2_text != blank %}<a href="{{ section.settings.col1_link2_url }}" class="footer-link">{% if section.settings.col1_link2_icon != blank %}<i class="{{ section.settings.col1_link2_icon }}"></i>{% endif %}<span>{{ section.settings.col1_link2_text }}</span></a>{% endif %}
        {% if section.settings.col1_link3_text != blank %}<a href="{{ section.settings.col1_link3_url }}" class="footer-link">{% if section.settings.col1_link3_icon != blank %}<i class="{{ section.settings.col1_link3_icon }}"></i>{% endif %}<span>{{ section.settings.col1_link3_text }}</span></a>{% endif %}
        {% if section.settings.col1_link4_text != blank %}<a href="{{ section.settings.col1_link4_url }}" class="footer-link">{% if section.settings.col1_link4_icon != blank %}<i class="{{ section.settings.col1_link4_icon }}"></i>{% endif %}<span>{{ section.settings.col1_link4_text }}</span></a>{% endif %}
      </div>

      <div class="footer-col">
        <h4>{{ section.settings.col2_title }}</h4>
        {% if section.settings.col2_link1_text != blank %}<a href="{{ section.settings.col2_link1_url }}" class="footer-link">{% if section.settings.col2_link1_icon != blank %}<i class="{{ section.settings.col2_link1_icon }}"></i>{% endif %}<span>{{ section.settings.col2_link1_text }}</span></a>{% endif %}
        {% if section.settings.col2_link2_text != blank %}<a href="{{ section.settings.col2_link2_url }}" class="footer-link">{% if section.settings.col2_link2_icon != blank %}<i class="{{ section.settings.col2_link2_icon }}"></i>{% endif %}<span>{{ section.settings.col2_link2_text }}</span></a>{% endif %}
        {% if section.settings.col2_link3_text != blank %}<a href="{{ section.settings.col2_link3_url }}" class="footer-link">{% if section.settings.col2_link3_icon != blank %}<i class="{{ section.settings.col2_link3_icon }}"></i>{% endif %}<span>{{ section.settings.col2_link3_text }}</span></a>{% endif %}
        {% if section.settings.col2_link4_text != blank %}<a href="{{ section.settings.col2_link4_url }}" class="footer-link">{% if section.settings.col2_link4_icon != blank %}<i class="{{ section.settings.col2_link4_icon }}"></i>{% endif %}<span>{{ section.settings.col2_link4_text }}</span></a>{% endif %}
        {% if section.settings.col2_link5_text != blank %}<a href="{{ section.settings.col2_link5_url }}" class="footer-link">{% if section.settings.col2_link5_icon != blank %}<i class="{{ section.settings.col2_link5_icon }}"></i>{% endif %}<span>{{ section.settings.col2_link5_text }}</span></a>{% endif %}
      </div>

      <div class="footer-col">
        <h4>{{ section.settings.contact_title }}</h4>
        {% if section.settings.contact_address != blank %}<a href="{{ section.settings.contact_map_link }}" target="_blank" class="contact-link"><i class="fas fa-map-marker-alt"></i><span>{{ section.settings.contact_address }}</span></a>{% endif %}
        {% if section.settings.contact_email != blank %}<a href="mailto:{{ section.settings.contact_email }}" class="contact-link"><i class="fas fa-envelope"></i><span>{{ section.settings.contact_email }}</span></a>{% endif %}
        {% if section.settings.contact_phone != blank %}<a href="https://wa.me/{{ section.settings.contact_phone | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" class="contact-link"><i class="fab fa-whatsapp"></i><span>{{ section.settings.contact_phone }}</span></a>{% endif %}
      </div>
    </div>

    <div class="footer-bottom">
      <div class="copyright">&copy; {{ 'now' | date: "%Y" }} {{ section.settings.copyright_text }}. All Rights Reserved.</div>
      <div class="social-icons">
        {% if section.settings.social_instagram != blank %}<a href="{{ section.settings.social_instagram }}" target="_blank"><i class="fab fa-instagram"></i></a>{% endif %}
        {% if section.settings.social_facebook != blank %}<a href="{{ section.settings.social_facebook }}" target="_blank"><i class="fab fa-facebook"></i></a>{% endif %}
        {% if section.settings.social_google != blank %}<a href="{{ section.settings.social_google }}" target="_blank"><i class="fab fa-google"></i></a>{% endif %}
      </div>
    </div>
  </footer>
</div>

